<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dino.presentation.controllers.GameOverController"
      alignment="CENTER"
      spacing="24"
      style="-fx-background-color: #0f1724; -fx-padding: 60;">

    <Label text="THREADED"
           style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <Label fx:id="winnerLabel"
           text="Ganador: —"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #80ed99;"/>

    <Label fx:id="totalTimeLabel"
           text="Tiempo total: 0.0s"
           style="-fx-font-size: 16px; -fx-text-fill: #b6c2d9;"/>

    <VBox spacing="8" maxWidth="560">
        <Label text="Resultado final"
               style="-fx-text-fill: #b6c2d9; -fx-font-size: 13px;"/>
        <TableView fx:id="resultsTable" prefHeight="280">
            <columns>
                <TableColumn fx:id="posColumn" text="Posicion" prefWidth="90"/>
                <TableColumn fx:id="nameColumn" text="Jugador" prefWidth="250"/>
                <TableColumn fx:id="scoreColumn" text="Puntaje" prefWidth="170"/>
            </columns>
        </TableView>
    </VBox>

    <Button text="VOLVER AL MENU"
            onAction="#onVolverAlMenu"
            style="-fx-background-color: #4cc9f0; -fx-text-fill: #0f1724; -fx-font-weight: bold;
                   -fx-font-size: 15px; -fx-padding: 12 40; -fx-background-radius: 6;"/>
</VBox>
