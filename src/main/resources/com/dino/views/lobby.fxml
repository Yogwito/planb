<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dino.presentation.controllers.LobbyController"
      alignment="CENTER"
      spacing="24"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Label text="SALA DE ESPERA"
           style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Arial';"/>

    <Label text="Esperando jugadores..."
           style="-fx-font-size: 14px; -fx-text-fill: #e94560; -fx-font-style: italic;"/>

    <VBox spacing="8" maxWidth="500" style="-fx-padding: 10 0;">
        <Label text="Jugadores conectados:" style="-fx-text-fill: #aaaacc; -fx-font-size: 13px;"/>
        <ListView fx:id="playersList"
                  prefHeight="200"
                  style="-fx-background-color: #16213e; -fx-border-color: #333366; -fx-border-radius: 6;
                         -fx-background-radius: 6; -fx-control-inner-background: #16213e;"/>
    </VBox>

    <HBox spacing="16" alignment="CENTER">
        <Button text="LISTO"
                fx:id="readyBtn"
                onAction="#onListo"
                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-font-size: 15px; -fx-padding: 12 40; -fx-background-radius: 6; -fx-cursor: hand;"/>

        <Button text="INICIAR PARTIDA"
                fx:id="startBtn"
                onAction="#onIniciarPartida"
                visible="false"
                style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-font-size: 15px; -fx-padding: 12 40; -fx-background-radius: 6; -fx-cursor: hand;
                       -fx-border-color: #e94560; -fx-border-radius: 6;"/>
    </HBox>

    <Label fx:id="statusLabel" text=""
           style="-fx-text-fill: #aaaacc; -fx-font-size: 12px;"/>
</VBox>
