<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.dino.presentation.controllers.GameController"
            style="-fx-background-color: #0d0d1a;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #16213e; -fx-padding: 12 20; -fx-border-color: #e94560;
                     -fx-border-width: 0 0 2 0;">
            <Label text="DINO ARENA"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;
                          -fx-font-family: 'Arial';"/>
            <Label fx:id="massLabel" text="Masa: 0"
                   style="-fx-text-fill: #ffd166; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Label fx:id="zoomLabel" text="Zoom: 1.0x"
                   style="-fx-text-fill: #8be9fd; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="TIEMPO:" style="-fx-text-fill: #aaaacc; -fx-font-size: 16px;"/>
            <Label fx:id="timerLabel" text="60"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e94560;
                          -fx-min-width: 60px;"/>
        </HBox>
    </top>

    <center>
        <StackPane>
            <Canvas fx:id="arenaCanvas" width="900" height="620"/>
            <VBox alignment="TOP_CENTER" mouseTransparent="true" pickOnBounds="false"
                  spacing="8" StackPane.alignment="TOP_CENTER" style="-fx-padding: 16 0 0 0;">
                <Label fx:id="feedbackLabel" text=""
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;
                              -fx-background-color: rgba(13,13,26,0.65); -fx-padding: 8 14;
                              -fx-background-radius: 16;"/>
            </VBox>
        </StackPane>
    </center>

    <right>
        <VBox spacing="16"
              style="-fx-background-color: #16213e; -fx-padding: 16; -fx-min-width: 220px;
                     -fx-border-color: #333366; -fx-border-width: 0 0 0 1;">
            <Label text="PUNTUACIONES"
                   style="-fx-text-fill: #e94560; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            <ListView fx:id="scoreBoard"
                      prefHeight="300"
                      style="-fx-background-color: #0d0d1a; -fx-border-color: #333366; -fx-border-radius: 4;
                             -fx-background-radius: 4; -fx-control-inner-background: #0d0d1a;"/>
            <Label text="EVENTOS"
                   style="-fx-text-fill: #e94560; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            <ListView fx:id="eventLog"
                      prefHeight="200"
                      style="-fx-background-color: #0d0d1a; -fx-border-color: #333366; -fx-border-radius: 4;
                             -fx-background-radius: 4; -fx-control-inner-background: #0d0d1a;"/>
        </VBox>
    </right>
</BorderPane>
