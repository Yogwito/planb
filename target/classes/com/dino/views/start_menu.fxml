<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dino.presentation.controllers.StartMenuController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Label text="DINO ARENA"
           style="-fx-font-size: 56px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Arial';"/>

    <Label text="Multijugador UDP"
           style="-fx-font-size: 18px; -fx-text-fill: #e94560; -fx-font-style: italic;"/>

    <VBox spacing="8" maxWidth="400" style="-fx-padding: 20 0 10 0;">
        <Label text="Nombre del jugador"
               style="-fx-text-fill: #aaaacc; -fx-font-size: 13px;"/>
        <TextField fx:id="playerNameField"
                   promptText="Tu nombre"
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #666699;
                          -fx-border-color: #e94560; -fx-border-radius: 4; -fx-background-radius: 4;
                          -fx-padding: 10; -fx-font-size: 14px;"/>
    </VBox>

    <HBox spacing="24" alignment="CENTER">
        <RadioButton fx:id="createRadio"
                     text="Crear sala"
                     style="-fx-text-fill: white; -fx-font-size: 14px;"
                     selected="true">
            <toggleGroup>
                <ToggleGroup fx:id="modeToggle"/>
            </toggleGroup>
        </RadioButton>

        <RadioButton fx:id="joinRadio"
                     text="Unirse"
                     style="-fx-text-fill: white; -fx-font-size: 14px;">
            <toggleGroup>
                <fx:reference source="modeToggle"/>
            </toggleGroup>
        </RadioButton>
    </HBox>

    <GridPane hgap="16" vgap="10" maxWidth="500" style="-fx-padding: 10 0;">
        <columnConstraints>
            <ColumnConstraints minWidth="140" prefWidth="140"/>
            <ColumnConstraints minWidth="200" prefWidth="200"/>
        </columnConstraints>

        <Label text="IP local:"
               style="-fx-text-fill: #aaaacc;"
               GridPane.rowIndex="0"
               GridPane.columnIndex="0"/>
        <TextField fx:id="localIpField"
                   text="0.0.0.0"
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-border-color: #333366;
                          -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;"
                   GridPane.rowIndex="0"
                   GridPane.columnIndex="1"/>

        <Label text="Puerto local:"
               style="-fx-text-fill: #aaaacc;"
               GridPane.rowIndex="1"
               GridPane.columnIndex="0"/>
        <TextField fx:id="localPortField"
                   text="5000"
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-border-color: #333366;
                          -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;"
                   GridPane.rowIndex="1"
                   GridPane.columnIndex="1"/>

        <Label text="IP host:"
               style="-fx-text-fill: #aaaacc;"
               GridPane.rowIndex="2"
               GridPane.columnIndex="0"/>
        <TextField fx:id="hostIpField"
                   promptText="192.168.x.x"
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #555588;
                          -fx-border-color: #333366; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;"
                   GridPane.rowIndex="2"
                   GridPane.columnIndex="1"/>

        <Label text="Puerto host:"
               style="-fx-text-fill: #aaaacc;"
               GridPane.rowIndex="3"
               GridPane.columnIndex="0"/>
        <TextField fx:id="hostPortField"
                   text="5000"
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-border-color: #333366;
                          -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;"
                   GridPane.rowIndex="3"
                   GridPane.columnIndex="1"/>
    </GridPane>

    <HBox fx:id="expectedPlayersBox" spacing="10" alignment="CENTER">
        <Label text="Jugadores esperados:"
               style="-fx-text-fill: #aaaacc; -fx-font-size: 13px;"/>
        <ChoiceBox fx:id="expectedPlayersChoice"
                   style="-fx-background-color: #16213e; -fx-border-color: #333366;
                          -fx-border-radius: 4; -fx-background-radius: 4;"/>
    </HBox>

    <Button text="ABRIR LOBBY"
            fx:id="openLobbyBtn"
            onAction="#onAbrirLobby"
            style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold;
                   -fx-font-size: 16px; -fx-padding: 14 50; -fx-background-radius: 6; -fx-cursor: hand;"
            maxWidth="300"/>

    <Label fx:id="errorLabel"
           style="-fx-text-fill: #e94560; -fx-font-size: 12px;"
           visible="false"/>
</VBox>